/* pages/favorites/favorites.wxss */
.container {
  min-height: 100vh;
  background: #F5F0E8;
  display: flex;
  flex-direction: column;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3E2723;
}

.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.tabs {
  display: flex;
  background: white;
  padding: 0 32rpx;
  border-bottom: 1rpx solid #F0EDE8;
  flex-shrink: 0;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: #8D6E63;
  position: relative;
}

.tab-item.active {
  color: #2E7D32;
  font-weight: bold;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #2E7D32;
  border-radius: 2rpx;
}

.favorites-list {
  flex: 1;
  padding: 20rpx 2rpx;
  overflow-y: auto;
  height: 0;  
}

.favorite-item {
  background: white;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.item-content {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  overflow: hidden;
  min-height: 120rpx; 
}

.item-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  overflow: hidden;
  flex-shrink: 0;
  background: #F5F0E8;
}

.cover-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cover-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  background: #E8F5E9;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  overflow: hidden;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #3E2723;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-time {
  font-size: 22rpx;
  color: #BDBDBD;
}

.item-delete {
  width: 80rpx;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  opacity: 0.5;
  flex-shrink: 0;
  padding: 24rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
}

.loading {
  display: flex;
  justify-content: center;
  padding: 60rpx;
  color: #BDBDBD;
}

.clear-btn {
  background: #FFF3F0;
  padding: 28rpx;
  text-align: center;
  font-size: 28rpx;
  color: #F44336;
  border-top: 1rpx solid #F0EDE8;
  margin-bottom: env(safe-area-inset-bottom);
  flex-shrink: 0;
}

.clear-btn:active {
  background: #FFE8E5;
}