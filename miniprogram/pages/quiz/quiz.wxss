/* pages/quiz/quiz.wxss */
page {
  background: #F5F0E8;
}

.quiz-page {
  min-height: 100vh;
  background: #F5F0E8;
}

/* ========== 自定义导航栏 ========== */
.quiz-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 140rpx;
  background: linear-gradient(135deg, #F5F0E8 0%, #F5F0E8 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 50rpx 32rpx 0;
  box-sizing: border-box;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(138, 138, 138, 0.2);
}

.back-btn text {
  font-size: 40rpx;
  color: rgb(243, 237, 237);
  font-weight: 500;
}

.quiz-title {
  font-size: 26rpx;
  color: rgb(9, 9, 9);
  letter-spacing: 4rpx;
}

.placeholder {
  width: 60rpx;
}

/* ========== 内容区域 ========== */
.quiz-content {
  padding-top: 160rpx;
  padding-bottom: 40rpx;
}

/* ========== 进度区域 ========== */
.progress-section {
  background: white;
  padding: 24rpx 32rpx;
  margin: 0 24rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
  font-size: 26rpx;
  color: #8D6E63;
}

.progress-text {
  color: #2E7D32;
  font-weight: 500;
}

.score-text {
  color: #2E7D32;
  font-weight: 500;
}

.progress-bar {
  height: 12rpx;
  background: #F0EDE8;
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7D32, #4CAF50);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

/* ========== 题目卡片 ========== */
.question-card {
  background: white;
  padding: 40rpx 32rpx;
  border-radius: 24rpx;
  margin: 0 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
}

.question-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #3E2723;
  line-height: 1.5;
}

/* ========== 选项列表 ========== */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding: 0 24rpx;
}

.option-item {
  background: white;
  border-radius: 20rpx;
  padding: 24rpx 28rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  border: 2rpx solid #F0EDE8;
  transition: all 0.2s ease;
  box-shadow: 0 2rpx 8rpx rgba(93, 64, 55, 0.05);
}

.option-item.selected {
  border-color: #ffd05b;
  background: #E8F5E9;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.15);
}

.option-item.correct {
  border-color: #4CAF50;
  background: #E8F5E9;
}

.option-item.wrong {
  border-color: #F44336;
  background: #FFEBEE;
}

.option-marker {
  width: 52rpx;
  height: 52rpx;
  background: #F5F0E8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #8D6E63;
}

.option-item.selected .option-marker {
  background: #2E7D32;
  color: white;
}

.option-item.correct .option-marker {
  background: #2E7D32;
  color: white;
}

.option-item.wrong .option-marker {
  background: #F44336;
  color: white;
}

.option-text {
  flex: 1;
  font-size: 30rpx;
  color: #3E2723;
  line-height: 1.4;
}

.option-status {
  width: 44rpx;
  font-size: 36rpx;
  text-align: center;
}

/* ========== 解析卡片 ========== */
.explanation-card {
  background: #FFF8E1;
  padding: 28rpx;
  border-radius: 20rpx;
  margin: 32rpx 24rpx 0;
  border-left: 8rpx solid #FFC107;
}

.explanation-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 12rpx;
}

.explanation-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

/* ========== 按钮区域 ========== */
.action-buttons {
  padding: 40rpx 24rpx;
}

.submit-btn, .next-btn {
  width: 100%;
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  color: white;
  border-radius: 60rpx;
  padding: 28rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
  border: none;
}

.submit-btn::after, .next-btn::after {
  border: none;
}

.submit-btn:active, .next-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ========== 结果卡片 ========== */
.result-card {
  background: white;
  margin: 80rpx 32rpx;
  padding: 60rpx 40rpx;
  border-radius: 32rpx;
  text-align: center;
  box-shadow: 0 8rpx 24rpx rgba(93, 64, 55, 0.1);
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #3E2723;
  margin-bottom: 24rpx;
}

.result-score {
  margin-bottom: 24rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #2E7D32;
}

.score-total {
  font-size: 36rpx;
  color: #BDBDBD;
}

.result-desc {
  font-size: 28rpx;
  color: #8D6E63;
  margin-bottom: 48rpx;
  display: block;
}

.result-buttons {
  display: flex;
  gap: 24rpx;
}

.restart-btn, .back-home-btn {
  flex: 1;
  padding: 28rpx;
  border-radius: 60rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.restart-btn::after, .back-home-btn::after {
  border: none;
}

.restart-btn {
  background: #F5F0E8;
  color: #2E7D32;
  border: 2rpx solid #2E7D32;
}

.back-home-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  color: white;
}

.restart-btn:active, .back-home-btn:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  color: #BDBDBD;
  font-size: 28rpx;
}

.loading-wrap text {
  margin-top: 20rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #F0EDE8;
  border-top-color: #2E7D32;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.dots-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #F0EDE8;
  transition: all 0.3s ease;
}

.dot.active {
  background: #4CAF50;
}

.dot.current {
  width: 24rpx;
  height: 24rpx;
  background: #2E7D32;
  box-shadow: 0 0 8rpx rgba(46, 125, 50, 0.5);
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}