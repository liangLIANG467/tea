/* 我的茶园页面样式 */
.garden-page {
  width: 100%;
  height: 100vh;
  background: #F5F0E8;
  position: relative;
  overflow: hidden;
}

/* 自定义导航栏 - 高度增加 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 140rpx;        
  padding: 60rpx 32rpx 0; 
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #F5F0E8 0%, #F5F0E8 100%);
  z-index: 100;
}


.nav-bar-back {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.1);
}

.back-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.nav-bar-title {
  font-size: 25rpx;
  font-weight: bold;
  color: #151414;
  letter-spacing: 5rpx;
}

.nav-bar-right {
  width: 68rpx;
  height: 68rpx;
}

.more-btn {
  width: 68rpx;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.2);
}

.more-icon {
  font-size: 44rpx;
  color: #FFFFFF;
  font-weight: bold;
}

/* 内容区域 - 支持竖屏滑动 */
.garden-content {
  height: 100vh;
  padding-bottom: 40rpx;
  box-sizing: border-box;
  background: #F5F0E8;
}

/* 外层容器 - 左右留白 */
.container {
  padding-left: 5%;
  padding-right: 5%;
  width: 90%;
  margin: 0 auto;
  padding-bottom: 40rpx;
}

/* 统计卡片网格 */
.stats-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 32rpx;
  justify-content: center;
}

.stat-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx 16rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
  min-width: 0;
}

.stat-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 12rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #9E9E9E;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #2E7D32;
  display: block;
}

.stat-number-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 4rpx;
}

.stat-number {
  font-size: 52rpx;
  font-weight: bold;
  color: #2E7D32;
}

.stat-unit {
  font-size: 26rpx;
  color: #9E9E9E;
}

/* 生长进度卡片 */
.progress-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
}

.progress-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.progress-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E2723;
}

.progress-percent {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E7D32;
}

.progress-bar-wrap {
  height: 16rpx;
  background: #F0EDE8;
  border-radius: 8rpx;
  margin-bottom: 32rpx;
  overflow: hidden;
}

.progress-bar {
  height: 100%;
  background: linear-gradient(90deg, #2E7D32 0%, #4CAF50 100%);
  border-radius: 8rpx;
  width: 0;
  transition: width 0.5s ease;
}

.progress-stages {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.stage-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.stage-dot {
  width: 20rpx;
  height: 20rpx;
  background: #E0E0E0;
  border-radius: 50%;
}

.stage-dot.active {
  background: #2E7D32;
  box-shadow: 0 0 0 6rpx rgba(46, 125, 50, 0.15);
}

.stage-name {
  font-size: 22rpx;
  color: #BDBDBD;
}

.stage-name.active {
  color: #2E7D32;
  font-weight: 500;
}

.stage-line {
  flex: 1;
  height: 4rpx;
  background: #E0E0E0;
  margin: 0 8rpx;
}

.stage-line.active {
  background: #2E7D32;
}

/* AI巡检按钮 */
.inspect-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-radius: 28rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.25);
  transition: all 0.2s ease;
}

.inspect-btn:active {
  transform: scale(0.98);
}

.inspect-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.inspect-text {
  flex: 1;
}

.inspect-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #FFFFFF;
  display: block;
  margin-bottom: 8rpx;
}

.inspect-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.inspect-arrow {
  font-size: 48rpx;
  color: #FFFFFF;
  opacity: 0.8;
}

/* 今日任务卡片 */
.task-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
}

.task-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.task-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E2723;
}

.task-status {
  font-size: 24rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
}

.task-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.task-checkbox {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  border: 2rpx solid #E0E0E0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.task-checkbox.checked {
  background: #2E7D32;
  border-color: #2E7D32;
}

.task-checkbox.checked text {
  color: #FFFFFF;
  font-size: 24rpx;
}

.task-text {
  flex: 1;
  font-size: 28rpx;
  color: #5D4037;
}

/* 巡检报告卡片 */
.report-card {
  background: #FFFFFF;
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
}

.report-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.report-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E2723;
}

.report-expand {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #9E9E9E;
}

.expand-icon {
  font-size: 20rpx;
}

.report-content {
  overflow: hidden;
  transition: all 0.3s ease;
  max-height: 120rpx;
}

.report-content.expanded {
  max-height: 500rpx;
}

.report-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #757575;
  display: block;
  margin-bottom: 20rpx;
}

.report-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  background: #F5F0E8;
  padding: 12rpx 24rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5D4037;
}

.report-footer {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0EDE8;
}

.report-time {
  font-size: 22rpx;
  color: #BDBDBD;
}

/* 连接状态 */
.connect-status {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 20rpx 28rpx;
  background: #FFFFFF;
  border-radius: 48rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(93, 64, 55, 0.05);
}

.status-dot {
  width: 16rpx;
  height: 16rpx;
  background: #4CAF50;
  border-radius: 50%;
  animation: pulse 1.5s infinite;
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
  }
  50% {
    opacity: 0.4;
  }
}

.status-text {
  flex: 1;
  font-size: 26rpx;
  color: #757575;
}

.status-more {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 500;
}

/* 底部安全区域 */
.safe-area-bottom {
  height: env(safe-area-inset-bottom);
  height: constant(safe-area-inset-bottom);
  padding-bottom: 30rpx;
}