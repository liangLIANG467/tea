/* 首页样式 */
.index-page {
  min-height: 100vh;
  background: #F5F0E8;
  padding: 32rpx 32rpx 0;
  box-sizing: border-box;
}

/* ========== 轮播图样式 ========== */
.swiper {
  width: 100%;
  height: 320rpx;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.1);
}

.swiper-image {
  width: 100%;
  height: 100%;
}

/* ========== 功能入口网格 2x2 ========== */
.function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.grid-item {
  background: #FFFDF9;        /* 暖米白卡片背景 */
  border: 1rpx solid #E8DDD2; /* 淡棕色描边 */
  border-radius: 28rpx;
  padding: 32rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.06);
  transition: all 0.2s ease;
}

.grid-item:active {
  transform: scale(0.96);
  background: #F9F5EE;
}

.item-icon {
  font-size: 52rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #5D4037;  /* 深棕色文字 */
}

/* ========== 今日茶知识卡片 ========== */
.knowledge-card {
  background: #FFFDF9;        /* 暖米白卡片背景 */
  border: 1rpx solid #E8DDD2; /* 淡棕色描边 */
  border-radius: 28rpx;
  padding: 32rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.06);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;  /* 深棕色文字 */
}

.card-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: #6B8C42;  /* 茶绿色标签（更接近图片中的淡绿） */
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
}

.card-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #8D6E63;  /* 棕灰色正文 */
  display: block;
  margin-bottom: 24rpx;
}

.card-footer {
  font-size: 24rpx;
  color: #C4B5A5;  /* 浅棕色 */
  display: block;
  text-align: right;
}

/* ========== 六堡茶文化文章区域 ========== */
.section-title {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 16rpx 0 24rpx 0;
  margin-top: 8rpx;
}

.section-title text:first-child {
  font-size: 34rpx;
  font-weight: bold;
  color: #5D4037;  /* 深棕色标题 */
  letter-spacing: 1rpx;
}

.more-link {
  font-size: 26rpx;
  color: #8D6E63;
  font-weight: normal;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(141, 110, 99, 0.1);
}

.more-link:active {
  background: rgba(141, 110, 99, 0.2);
}

/* 文章卡片 */
.article-card {
  background: #FFFDF9;        /* 暖米白卡片背景 */
  border: 1rpx solid #E8DDD2; /* 淡棕色描边 */
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(93, 64, 55, 0.06);
  transition: all 0.2s ease;
}

.article-card:active {
  transform: scale(0.98);
  background: #F9F5EE;
}

.article-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.article-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: #EFE8DF;  /* 图标背景色 */
  flex-shrink: 0;
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.article-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5D4037;  /* 深棕色标题 */
  display: block;
}

.article-type {
  font-size: 24rpx;
  color: #6B8C42;  /* 茶绿色类型标签文字 */
  display: inline-block;
  background: rgba(107, 140, 66, 0.12);  /* 茶绿色浅背景 */
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  align-self: flex-start;
}

.article-desc {
  font-size: 26rpx;
  color: #8D6E63;  /* 棕灰色正文 */
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ========== 底部留白 ========== */
.bottom-space {
  height: 60rpx;
}
/* 今日茶知识卡片样式 */
.knowledge-card {
  background: linear-gradient(135deg, #fff9f0 0%, #fff5e8 100%);
  border-radius: 24rpx;
  padding: 28rpx 32rpx;
  margin: 24rpx 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(93, 64, 55, 0.08);
  border: 1rpx solid #f0e0c0;
}

.knowledge-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.knowledge-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  font-size: 30rpx;
  font-weight: bold;
  color: #5D4037;
}

.title-icon {
  font-size: 36rpx;
}

.knowledge-actions {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.collect-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.05);
  transition: all 0.2s ease;
}

.collect-btn.collected {
  background: rgba(255, 107, 107, 0.15);
}

.collect-icon {
  font-size: 28rpx;
}

.collect-text {
  font-size: 24rpx;
  color: #8D6E63;
}

.collect-btn.collected .collect-text {
  color: #E57373;
}

.refresh-btn {
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  background: rgba(0, 0, 0, 0.05);
}

.refresh-icon {
  font-size: 28rpx;
}

.knowledge-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #3E2723;
  margin-bottom: 16rpx;
}

.knowledge-source {
  text-align: right;
  font-size: 24rpx;
  color: #BDBDBD;
}