/* pages/map/map.wxss */

/* 地图导览页面样式 */
.map-page {
  position: relative;
  width: 100%;
  height: 100vh;
  background-color: #F5F0E8;
  overflow: hidden;
}

/* 自定义导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 160rpx;
  background: linear-gradient(135deg, #F5F0E8 0%, #F5F0E8 100%);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx;
  padding-top: 60rpx;
  box-sizing: border-box;
  z-index: 100;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.nav-bar-back {
  width: 55rpx;
  height: 55rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.1);
  margin-top: 10rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.nav-bar-title {
  font-size: 25rpx;
  color: #141313;
  letter-spacing: 5px;
  font-weight: 500;
}

.nav-bar-right {
  width: 60rpx;
  height: 60rpx;
}

.relocate-btn {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.relocate-icon {
  font-size: 32rpx;
}

/* ====== 省份选择栏 ====== */
.province-scroll-wrap {
  position: fixed;
  top: 150rpx;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 16rpx 0;
  border-bottom: 2rpx solid #F0EDE8;
  z-index: 99;
  height: 80rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(93, 64, 55, 0.05);
}

.province-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
  height: 100%;
}

.province-list {
  display: inline-flex;
  gap: 16rpx;
  padding: 4rpx 0;
  height: 100%;
  align-items: center;
}

.province-item {
  display: inline-block;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  color: #8D6E63;
  background: #F5F0E8;
  transition: all 0.3s ease;
  border: 2rpx solid transparent;
  white-space: nowrap;
}

.province-item.active {
  color: #FFFFFF;
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-color: #2E7D32;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.province-item:active {
  transform: scale(0.95);
}

.province-name {
  font-size: 26rpx;
  font-weight: 500;
}

/* 地图容器 */
.map-container {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  z-index: 1;
}

/* 地图加载提示 */
.map-loading {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: #FFFFFF;
  font-size: 24rpx;
}

/* 底部地点列表 */
.places-list {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 32rpx 32rpx 0 0;
  padding: 24rpx 0 20rpx;
  box-shadow: 0 -4rpx 20rpx rgba(93, 64, 55, 0.1);
  z-index: 98;
}

.places-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 0 32rpx 20rpx;
}

.places-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #3E2723;
}

.places-count {
  font-size: 24rpx;
  color: #9E9E9E;
}

.places-scroll {
  width: 100%;
  white-space: nowrap;
}

.places-scroll-inner {
  display: inline-flex;
  padding: 0 32rpx;
  gap: 20rpx;
}

.place-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #F5F0E8;
  border-radius: 20rpx;
  min-width: 120rpx;
  transition: all 0.3s ease;
}

.place-card.active {
  background: #2E7D32;
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(46, 125, 50, 0.3);
}

.place-card.active .place-name,
.place-card.active .place-distance {
  color: #FFFFFF;
}

.place-icon {
  font-size: 48rpx;
}

.place-info {
  text-align: center;
}

.place-name {
  font-size: 26rpx;
  font-weight: 500;
  color: #3E2723;
  display: block;
}

.place-distance {
  font-size: 22rpx;
  color: #9E9E9E;
  display: block;
  margin-top: 4rpx;
}

/* 底部信息卡片（弹窗） */
.info-card-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 200;
  display: flex;
  align-items: flex-end;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.info-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: 40rpx 40rpx 0 0;
  padding: 32rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.card-header-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.card-icon {
  font-size: 48rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #3E2723;
}

.card-close {
  width: 56rpx;
  height: 56rpx;
  background: #F5F0E8;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #9E9E9E;
}

/* 距离标签 */
.card-distance-tag {
  display: inline-block;
  background: #E8F5E9;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #2E7D32;
  margin-bottom: 24rpx;
}

/* 描述 */
.card-description {
  font-size: 28rpx;
  line-height: 1.6;
  color: #757575;
  margin-bottom: 24rpx;
}

/* 特色标签 */
.card-features {
  margin-bottom: 24rpx;
}

.features-label {
  font-size: 26rpx;
  font-weight: 500;
  color: #3E2723;
  display: block;
  margin-bottom: 12rpx;
}

.features-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.feature-tag {
  background: #F5F0E8;
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  color: #5D4037;
}

/* 地址、营业时间、联系方式 */
.card-address,
.card-hours,
.card-phone {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 0;
  border-top: 1rpx solid #F0EDE8;
  font-size: 26rpx;
  color: #757575;
}

.address-icon,
.hours-icon,
.phone-icon {
  font-size: 28rpx;
  width: 48rpx;
}

.address-text,
.hours-text,
.phone-text {
  flex: 1;
  line-height: 1.5;
}

/* 操作按钮 */
.card-actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #F0EDE8;
}

.action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  background: #F5F0E8;
  color: #5D4037;
}

.action-btn::after {
  border: none;
}

.detail-btn {
  background: #F5F0E8;
  color: #5D4037;
}

.nav-btn {
  background: #2E7D32;
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

/* 底部安全区域 */
.safe-area-bottom {
  height: constant(safe-area-inset-bottom);
  height: env(safe-area-inset-bottom);
  background: transparent;
}

/* 防止事件冒泡 */
.stop-propagation {
  /* 空样式用于事件绑定 */
}
