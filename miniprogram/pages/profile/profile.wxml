<!--
  我的页面
  六堡茶AI智能助手
-->
<view class="profile-page">
  <!-- 头部用户信息 -->
  <view class="user-header" bindtap="editProfile">
    <view class="user-avatar">
      <image wx:if="{{userInfo.avatarUrl}}" class="avatar-img" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <text wx:else class="avatar-default">👤</text>
    </view>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName}}</text>
      <text class="user-role">{{userInfo.role}}</text>
    </view>
    <view class="edit-icon">
      <text>✎</text>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-card">
    <view class="stat-item">
      <text class="stat-number">{{stats.diagnoseCount}}</text>
      <text class="stat-label">识别病害</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.chatCount}}</text>
      <text class="stat-label">提问次数</text>
    </view>
    <view class="stat-divider"></view>
    <view class="stat-item">
      <text class="stat-number">{{stats.favoriteCount}}</text>
      <text class="stat-label">收藏知识</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view class="section-title">我的功能</view>
    <view class="menu-list">
      <view 
        wx:for="{{menuItems}}" 
        wx:key="index"
        class="menu-item"
        bindtap="onMenuItemTap"
        data-item="{{item}}"
      >
        <view class="menu-icon">{{item.icon}}</view>
        <text class="menu-title">{{item.title}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="settings-section">
    <view class="section-title">设置</view>
    <view class="settings-list">
      <view 
        wx:for="{{settings}}" 
        wx:key="index"
        class="setting-item"
      >
        <view class="setting-icon">{{item.icon}}</view>
        <text class="setting-title">{{item.title}}</text>
        <view class="setting-control">
          <switch 
            wx:if="{{item.type === 'switch'}}"
            checked="{{item.value}}"
            bindchange="onSettingSwitch"
            data-index="{{index}}"
            color="#2E7D32"
          />
          <button 
            wx:else
            class="setting-btn"
            bindtap="openSetting"
            data-settingtype="{{item.settingType}}"
          >去设置</button>
        </view>
      </view>
    </view>
  </view>

  <!-- 其他操作 -->
  <view class="other-section">
    <view class="other-item" bindtap="showAbout">
      <text>关于我们</text>
      <text>›</text>
    </view>
    <view class="other-item" bindtap="clearCache">
      <text>清除缓存</text>
      <text>›</text>
    </view>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>版本 1.0.0</text>
  </view>

  <!-- 加载遮罩 -->
  <view class="loading-mask" wx:if="{{isLoading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>
  </view>
</view>