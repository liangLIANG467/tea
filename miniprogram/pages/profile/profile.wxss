/* 我的页面样式 */
.profile-page {
  min-height: 100vh;
  background: #F5F0E8;
  padding-bottom: 40rpx;
}

/* 用户头部 */
.user-header {
  background: linear-gradient(135deg, #e1be85 0%, #ebc993 100%);
  padding: 48rpx 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  position: relative;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.avatar-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.avatar-default {
  font-size: 60rpx;
}

.user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.user-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.user-role {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.edit-icon {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #FFFFFF;
}

/* 统计卡片 */
.stats-card {
  background: #FFFFFF;
  margin: -40rpx 32rpx 32rpx;
  padding: 40rpx 0;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: space-around;
  box-shadow: 0 8rpx 24rpx rgba(93, 64, 55, 0.1);
}

.stat-item {
  flex: 1;
  text-align: center;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.stat-number {
  font-size: 48rpx;
  font-weight: bold;
  color: #2E7D32;
}

.stat-label {
  font-size: 26rpx;
  color: #9E9E9E;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #F0EDE8;
}

/* 功能菜单 */
.menu-section,
.settings-section {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #3E2723;
  padding: 24rpx 32rpx 16rpx;
  border-bottom: 1rpx solid #F0EDE8;
}

.menu-list,
.settings-list {
  padding: 8rpx 0;
}

.menu-item,
.setting-item {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #F5F0E8;
}

.menu-item:active,
.setting-item:active {
  background: #F5F0E8;
}

.menu-icon,
.setting-icon {
  font-size: 40rpx;
  width: 56rpx;
}

.menu-title,
.setting-title {
  flex: 1;
  font-size: 28rpx;
  color: #3E2723;
}

.menu-arrow {
  font-size: 36rpx;
  color: #BDBDBD;
}

.setting-control {
  display: flex;
  align-items: center;
}

.setting-btn {
  background: #F5F0E8;
  color: #5D4037;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 32rpx;
  margin: 0;
}

.setting-btn::after {
  border: none;
}

/* 其他操作 */
.other-section {
  background: #FFFFFF;
  margin: 0 32rpx 24rpx;
  border-radius: 24rpx;
  overflow: hidden;
}

.other-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F5F0E8;
  font-size: 28rpx;
  color: #3E2723;
}

.other-item:active {
  background: #F5F0E8;
}

.other-item:last-child {
  border-bottom: none;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 32rpx;
}

.version-info text {
  font-size: 24rpx;
  color: #BDBDBD;
}

/* 加载遮罩 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.loading-content {
  background: #FFFFFF;
  padding: 40rpx;
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0EDE8;
  border-top-color: #2E7D32;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}