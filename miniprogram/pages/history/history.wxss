/* pages/history/history.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 20rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
  gap: 15rpx;
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.count {
  font-size: 24rpx;
  color: #999;
  margin-left: 10rpx;
}

.header-buttons {
  display: flex;
  gap: 15rpx;
}

 .clear-btn {
  font-size: 24rpx;
  height: 56rpx;
  line-height: 56rpx;
}

.loading, .empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.empty-tip {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 40rpx;
}

.empty-btn {
  width: 240rpx;
  background: #2E7D32;
}

.image-grid {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.image-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.image-wrapper {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #f0f0f0;
}

.image {
  width: 100%;
  height: 100%;
}

.image-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.6);
  color: white;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.image-info {
  padding: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.info-row {
  display: flex;
  margin-bottom: 10rpx;
  font-size: 26rpx;
}

.info-label {
  width: 140rpx;
  color: #999;
}

.info-value {
  flex: 1;
  color: #333;
  word-break: break-all;
}

.confidence {
  color: #4CAF50;
  font-weight: bold;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
}

.save-btn, .delete-btn {
  flex: 1;
  font-size: 26rpx;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 34rpx;
}

.save-btn {
  background: #2E7D32;
  color: white;
  border: none;
}

.delete-btn {
  background: #FFF3F0;
  color: #F44336;
  border: none;
}