/* pages/detail/detail.wxss */

/* 页面容器 */
.detail-page {
  background: #F5F0E8;
  min-height: 100vh;
  padding-bottom: 140rpx;
}

/* 封面图片 - 顶部全宽 */
.cover-image {
  width: 100%;
  height: 480rpx;
  object-fit: cover;
  display: block;
}

/* 标题区域 - 圆角卡片悬浮效果 */
.title-section {
  padding: 36rpx 36rpx 24rpx;
  background: #FFFFFF;
  margin: -32rpx 28rpx 0;
  border-radius: 32rpx 32rpx 0 0;
  position: relative;
  z-index: 2;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.03);
}

.article-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #3E2723;
  line-height: 1.4;
  display: block;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.type-tag {
  display: inline-block;
  font-size: 24rpx;
  color: #6B8C42;
  background: rgba(107, 140, 66, 0.12);
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

/* 正文内容区域 */
.content-section {
  padding: 36rpx 36rpx 80rpx;
  background: #FFFFFF;
  margin: 0 28rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.article-content {
  font-size: 30rpx;
  line-height: 1.9;
  color: #5D4037;
  text-align: justify;
  display: block;
  white-space: pre-wrap;
  word-break: break-word;
}

/* 首字下沉效果（可选） */
.article-content::first-letter {
  font-size: 60rpx;
  font-weight: bold;
  color: #6B8C42;
  margin-right: 8rpx;
  float: left;
  line-height: 1;
}

/* 加载中状态 */
.loading-wrap {
  padding: 200rpx;
  text-align: center;
  color: #8D6E63;
  font-size: 28rpx;
  background: #F5F0E8;
  height: 100vh;
}

/* ========== 底部操作栏（固定绿色按钮） ========== */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: transparent;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.share-main-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  border-radius: 60rpx;
  padding: 24rpx 80rpx;
  width: auto;
  margin: 0;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
  border: none;
}

.share-main-btn::after {
  border: none;
}

.share-main-btn .action-icon {
  font-size: 36rpx;
}

.share-main-btn .action-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #FFFFFF;
}

.btn-hover {
  opacity: 0.85;
  transform: scale(0.97);
  transition: all 0.2s ease;
}