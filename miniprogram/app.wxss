/**
 * 全局样式文件
 * 六堡茶AI智能助手 - 新中式自然风格
 */

/* ==================== 变量定义 ==================== */
page {
  /* 主色调 */
  --primary-color: #5D4037;
  --secondary-color: #2E7D32;
  --accent-color: #8D6E63;
  --light-green: #A5D6A7;
  
  /* 背景色 */
  --bg-color: #F5F0E8;
  --bg-color-light: #FAF7F2;
  --card-bg: #FFFFFF;
  
  /* 文字色 */
  --text-primary: #3E2723;
  --text-secondary: #9E9E9E;
  --text-white: #FFFFFF;
  
  /* 圆角 */
  --radius-small: 12rpx;
  --radius-medium: 16rpx;
  --radius-large: 24rpx;
  --radius-circle: 50%;
  
  /* 阴影 */
  --shadow-card: 0 2rpx 8rpx rgba(93, 64, 55, 0.1);
  --shadow-button: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
  --shadow-popup: 0 8rpx 24rpx rgba(93, 64, 55, 0.15);
  
  /* 间距 */
  --spacing-xs: 10rpx;
  --spacing-sm: 16rpx;
  --spacing-md: 20rpx;
  --spacing-lg: 30rpx;
  --spacing-xl: 40rpx;
  
  /* 字体大小 */
  --font-size-xs: 24rpx;
  --font-size-sm: 26rpx;
  --font-size-md: 28rpx;
  --font-size-lg: 32rpx;
  --font-size-xl: 36rpx;
  --font-size-xxl: 40rpx;
}

/* ==================== 全局重置 ==================== */
page {
  background-color: var(--bg-color);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-size-md);
  color: var(--text-primary);
  line-height: 1.6;
}

/* ==================== 通用容器 ==================== */
.container {
  min-height: 100vh;
  background-color: var(--bg-color);
}

.view-page {
  padding: 0;
  min-height: calc(100vh - 180rpx);
  background-color: var(--bg-color);
}

/* ==================== 导航栏 ==================== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, var(--primary-color) 0%, var(--secondary-color) 100%);
  position: relative;
}

.nav-bar-back {
  position: absolute;
  left: 24rpx;
  display: flex;
  align-items: center;
  color: var(--text-white);
  font-size: 28rpx;
}

.nav-bar-title {
  color: var(--text-white);
  font-size: var(--font-size-lg);
  font-weight: 500;
}

/* ==================== 卡片样式 ==================== */
.card {
  background-color: var(--card-bg);
  border-radius: var(--radius-large);
  box-shadow: var(--shadow-card);
  padding: var(--spacing-md);
  margin: var(--spacing-sm);
}

.card-title {
  font-size: var(--font-size-lg);
  color: var(--text-primary);
  font-weight: 600;
  margin-bottom: var(--spacing-sm);
}

.card-content {
  font-size: var(--font-size-md);
  color: var(--text-secondary);
  line-height: 1.8;
}

/* ==================== 按钮样式 ==================== */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: var(--radius-large);
  font-size: var(--font-size-md);
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, var(--secondary-color) 0%, #1B5E20 100%);
  color: var(--text-white);
  box-shadow: var(--shadow-button);
}

.btn-primary:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-secondary {
  background-color: var(--card-bg);
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
}

.btn-secondary:active {
  background-color: var(--bg-color);
}

.btn-small {
  height: 64rpx;
  padding: 0 var(--spacing-md);
  font-size: var(--font-size-sm);
  border-radius: var(--radius-small);
}

.btn-full {
  width: 100%;
}

/* ==================== 输入框 ==================== */
.input-wrapper {
  display: flex;
  align-items: center;
  background-color: var(--card-bg);
  border-radius: var(--radius-medium);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 2rpx solid #E8E0D8;
}

.input-wrapper:focus-within {
  border-color: var(--secondary-color);
}

.input-field {
  flex: 1;
  height: 72rpx;
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

.input-placeholder {
  color: var(--text-secondary);
}

/* ==================== 功能卡片网格 ==================== */
.grid-cards {
  display: flex;
  flex-wrap: wrap;
  padding: var(--spacing-sm);
}

.grid-item {
  width: 50%;
  padding: var(--spacing-xs);
  box-sizing: border-box;
}

.function-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: var(--card-bg);
  border-radius: var(--radius-large);
  padding: var(--spacing-lg) var(--spacing-sm);
  box-shadow: var(--shadow-card);
}

.function-card-icon {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color);
  border-radius: var(--radius-circle);
  margin-bottom: var(--spacing-sm);
  font-size: 40rpx;
}

.function-card-title {
  font-size: var(--font-size-md);
  color: var(--text-primary);
  font-weight: 500;
  text-align: center;
}

.function-card-desc {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 8rpx;
  text-align: center;
}

/* ==================== 标签样式 ==================== */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: var(--radius-small);
  font-size: var(--font-size-xs);
}

.tag-primary {
  background-color: rgba(93, 64, 55, 0.1);
  color: var(--primary-color);
}

.tag-success {
  background-color: rgba(46, 125, 50, 0.1);
  color: var(--secondary-color);
}

.tag-warning {
  background-color: rgba(255, 152, 0, 0.1);
  color: #FF9800;
}

/* ==================== 进度条 ==================== */
.progress-wrapper {
  display: flex;
  align-items: center;
}

.progress-bar {
  flex: 1;
  height: 16rpx;
  background-color: #E8E0D8;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--secondary-color) 0%, var(--light-green) 100%);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  margin-left: var(--spacing-sm);
  font-size: var(--font-size-sm);
  color: var(--text-secondary);
  min-width: 80rpx;
}

/* ==================== 列表项 ==================== */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--spacing-md);
  background-color: var(--card-bg);
  border-bottom: 1rpx solid #F0EBE5;
}

.list-item:last-child {
  border-bottom: none;
}

.list-item-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--spacing-md);
  font-size: 28rpx;
}

.list-item-content {
  flex: 1;
}

.list-item-title {
  font-size: var(--font-size-md);
  color: var(--text-primary);
}

.list-item-desc {
  font-size: var(--font-size-xs);
  color: var(--text-secondary);
  margin-top: 4rpx;
}

.list-item-arrow {
  color: var(--text-secondary);
  font-size: 24rpx;
}

/* ==================== 空状态 ==================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xl);
  color: var(--text-secondary);
}

.empty-state-icon {
  font-size: 80rpx;
  margin-bottom: var(--spacing-md);
  opacity: 0.5;
}

.empty-state-text {
  font-size: var(--font-size-md);
}

/* ==================== 分隔线 ==================== */
.divider {
  height: 1rpx;
  background-color: #E8E0D8;
  margin: var(--spacing-sm) 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background-color: #E8E0D8;
}

/* ==================== 工具类 ==================== */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.text-center {
  text-align: center;
}

.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-white {
  color: var(--text-white);
}

.mt-sm { margin-top: var(--spacing-xs); }
.mt-md { margin-top: var(--spacing-sm); }
.mt-lg { margin-top: var(--spacing-lg); }
.mb-sm { margin-bottom: var(--spacing-xs); }
.mb-md { margin-bottom: var(--spacing-sm); }
.mb-lg { margin-bottom: var(--spacing-lg); }

/* ==================== 自定义TabBar ==================== */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background-color: var(--card-bg);
  display: flex;
  align-items: center;
  justify-content: space-around;
  padding-bottom: env(safe-area-inset-bottom);
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  z-index: 1000;
}

.tab-bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex: 1;
  padding: 10rpx 0;
}

.tab-bar-icon {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 6rpx;
  font-size: 40rpx;
}

.tab-bar-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.tab-bar-item.active .tab-bar-text {
  color: var(--primary-color);
}

/* ==================== 滚动区域 ==================== */
.scroll-view {
  height: calc(100vh - 120rpx);
}

/* ==================== 页面底部安全区 ==================== */
.safe-area-bottom {
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}
